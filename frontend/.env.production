# Same-origin → tgpayment (`/verifyPromoter`, `/saveRefAllocation`, …). See next.config.mjs `OSS_API_UPSTREAM`.
NEXT_PUBLIC_API_URL=/api-proxy

# Same-origin → Nest OSS API (`/numbers/search`, `/devices`, `/proxy`, `/payment`, …). Requires `OSS_NEST_UPSTREAM` on Vercel (build env).
NEXT_PUBLIC_NEST_API_URL=/oss-nest-proxy

# Optional: override tgpayment upstream (default https://www.tonewow.net/tgpayment)
# OSS_API_UPSTREAM=https://www.tonewow.net/tgpayment
